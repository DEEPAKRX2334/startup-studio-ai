# ==============================================================================
# Startup Studio AI - Local Environment Template
# ==============================================================================

# 1. Gemini API Key Configuration
# Retrieve yours from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# 2. Application Access Token Security (Optional API Header Protection)
# If provided, clients must pass X-Startup-Studio-Token matching this value
APP_SECRET_TOKEN=

# 3. Google Cloud Platform Configuration (Optional for GCP Secret Manager resolution)
# GCP_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/keyfile.json
